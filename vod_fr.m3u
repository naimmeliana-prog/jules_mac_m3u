#EXTINF:-1 tvg-logo="https://image.tmdb.org/t/p/w600_and_h900_bestv2/bP7u19opmHXYeTCUwGjlLldmUMc.jpg" group-title="|FR| FILMS UHD" description="Un jeune de 17 ans apprend que sa petite-amie n'a plus qu'une année à vivre." year="2020-11-27" director="Mitja Okorn" actors="Jaden Smith, Cara Delevingne, Cuba Gooding Jr., Chris D'Elia, JT Neal, Stony Blyden, Peter MacNeill, RZA, Nia Long, Michelle Giroux",FR - Life in a Year (2020)
http://mag.greatott.me:80/play/movie.php?mac=00:1A:79:74:B1:B9&stream=1394715.mkv&play_token=1KZUJiyisB&type=movie&dummy=/movie/&type=movie
